# =============================================================================
# Frontend environment variables — TEMPLATE (contains NO real secrets).
#
# Copy to .env.local (gitignored) for local dev, or set on Vercel for production.
# The backend has its own .env.example in back/.
# =============================================================================

# --- API proxy target -------------------------------------------------------
# The backend URL the Next.js server proxies /api/* to (next.config.mjs rewrites).
#   Local:        http://localhost:5000
#   Production:   https://your-backend-domain   (MUST be set in production)
BACKEND_URL=http://localhost:5000

# --- Browser API base URL (optional override) -------------------------------
# Controls where the browser sends API requests (src/api/api.ts).
#   - Unset in production: defaults to '' (relative) → uses the /api/* proxy
#   - Unset in dev:        defaults to http://localhost:5000 (direct to Express)
#   - Set to an absolute URL to bypass the proxy and use cross-origin CORS
#     (the backend CLIENT_ORIGIN allowlist must then permit this origin).
# NEXT_PUBLIC_API_URL=

# --- On-demand ISR revalidation ---------------------------------------------
# Shared secret protecting the /api/revalidate endpoint. Must match
# REVALIDATE_SECRET on the backend.
REVALIDATE_SECRET=replace-with-a-long-random-string
